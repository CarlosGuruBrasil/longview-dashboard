{
  "framework": "nextjs",
  "regions": ["gru1"],
  "crons": [
    { "path": "/api/cron/sync-leads",     "schedule": "0 */2 * * *" },
    { "path": "/api/cron/sync-audiences", "schedule": "0 6 * * 0" },
    { "path": "/api/cron/process-leads",  "schedule": "0 10 * * *" },
    { "path": "/api/cron/recalc-scores",  "schedule": "0 7 * * *" }
  ],
  "functions": {
    "src/app/api/meta/create-lead-ad/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/data/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/auth/login/route.ts": {
      "maxDuration": 10
    },
    "src/app/api/upload/route.ts": {
      "maxDuration": 15
    },
    "src/app/api/cron/sync-audiences/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/cron/process-leads/route.ts": {
      "maxDuration": 45
    },
    "src/app/api/cron/recalc-scores/route.ts": {
      "maxDuration": 45
    },
    "src/app/api/meta/capi/route.ts": {
      "maxDuration": 20
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    },
    {
      "source": "/(.*\\.png|.*\\.jpg|.*\\.webp|.*\\.svg|.*\\.ico)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/_next/static/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
